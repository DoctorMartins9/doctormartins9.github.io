<div class="news">
  {% assign news_entries = site.data.news %}
  {% if news_entries != blank %}
    {% assign news_size = news_entries | size %}
    <div
      class="table-responsive"
      {% if include.limit and page.announcements.scrollable and news_size > 3 %}
        style="max-height: 60vw"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% assign news = news_entries | sort: 'date' | reverse %}
        {% if include.limit and page.announcements.limit %}
          {% assign news_limit = page.announcements.limit %}
        {% else %}
          {% assign news_limit = news_size %}
        {% endif %}
        {% for item in news limit: news_limit %}
          <tr>
            <th scope="row" style="width: 20%">{{ item.date | date: '%b %d, %Y' }}</th>
            <td>
              {% if item.inline == false and item.title and item.url %}
                {% assign item_url = item.url | to_s %}
                {% if item_url contains '://' %}
                  <a class="news-title" href="{{ item_url }}" target="_blank" rel="noopener noreferrer">{{ item.title }}</a>
                {% else %}
                  <a class="news-title" href="{{ item_url | relative_url }}">{{ item.title }}</a>
                {% endif %}
              {% else %}
                {% assign item_content = item.content | default: item.title | default: '' %}
                {{ item_content | markdownify | remove: '<p>' | remove: '</p>' | strip | emojify }}
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
